# AVE CRM - Docker development
# Copy to .env: cp .env.docker.example .env
# Then: docker-compose exec backend-php php artisan key:generate

APP_NAME="AVE CRM"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=avecrm
DB_USERNAME=ave
DB_PASSWORD=avepwd

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

SESSION_DRIVER=file
CACHE_STORE=redis
QUEUE_CONNECTION=database
